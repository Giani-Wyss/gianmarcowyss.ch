{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "Angular packages",
      "matchPackageNames": [
        "@angular/*",
        "@angular-devkit/*",
        "@angular-eslint/*",
        "zone.js",
        "typescript"
      ]
    },
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "platformAutomerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ]
}
